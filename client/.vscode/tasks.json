{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build game.exe (GCC)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$ErrorActionPreference = 'Stop'; Stop-Process -Name 'game' -Force -ErrorAction SilentlyContinue; $sources = @((Resolve-Path 'main.c').Path) + @(Get-ChildItem 'src' -Filter '*.c' | ForEach-Object { $_.FullName }); & 'C:/mingw/bin/gcc.exe' $sources -o 'game.exe' -O1 -Wall -std=c99 -Wno-missing-braces -I 'include' -g -L 'lib' -lraylib -lopengl32 -lgdi32 -lws2_32 -lwinmm -Wno-unused-function -Wno-maybe-uninitialized -Wno-switch; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Builds the full raylib client with MinGW GCC."
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}